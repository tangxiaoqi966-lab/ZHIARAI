# 多租户Supabase平台环境变量配置示例
# 复制此文件为 .env 并根据需要修改值

## ======================
## 平台配置
## ======================

# API认证配置
# 开发测试阶段：保持默认值
# 生产部署：必须生成强随机密钥
API_AUTH_ENABLED=true
API_KEY=supabase-platform-secret-key-change-in-production

# 前端仪表板配置
NEXT_PUBLIC_API_KEY=${API_KEY}
NEXT_PUBLIC_API_URL=http://localhost:3002

## ======================
## Traefik反向代理配置（生产环境需要）
## ======================

# 生产域名（替换为您的实际域名）
TRAEFIK_DOMAIN=your-production-domain.com

# Let's Encrypt证书邮箱
TRAEFIK_ACME_EMAIL=admin@your-domain.com

# Traefik管理界面密码（可选）
TRAEFIK_ADMIN_PASSWORD=strong-password-here

## ======================
## 数据库配置（可选覆盖）
## ======================

# 主数据库连接（平台自身使用）
# PLATFORM_DB_HOST=localhost
# PLATFORM_DB_PORT=5432
# PLATFORM_DB_NAME=platform
# PLATFORM_DB_USER=postgres
# PLATFORM_DB_PASSWORD=change-me

## ======================
## 监控与日志配置（生产环境建议）
## ======================

# Prometheus监控
# PROMETHEUS_ENABLED=false
# PROMETHEUS_PORT=9090

# Grafana仪表板
# GRAFANA_ENABLED=false
# GRAFANA_PORT=3001

## ======================
## 部署模式配置
## ======================

# 部署环境：development, staging, production
NODE_ENV=development

# 调试模式
DEBUG=false

## ======================
## 使用说明
## ======================

# 1. 开发测试：
#    复制此文件为 .env，保持默认值即可
#    cp .env.example .env

# 2. 生产部署：
#    a. 复制此文件为 .env.production
#    b. 生成强随机API密钥：openssl rand -hex 32
#    c. 替换所有默认密码和密钥
#    d. 设置真实域名和邮箱
#    e. 根据需求启用监控和日志

# 3. 密钥安全：
#    - 不要将 .env 文件提交到版本控制
#    - 使用密钥管理服务存储生产密钥
#    - 定期轮换关键密钥（建议每90天）