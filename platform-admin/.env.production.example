# Supabase 平台管理后台 - 生产环境配置

# 数据库配置
DB_HOST=postgres
DB_PORT=5432
DB_NAME=supabase_platform
DB_USER=postgres
DB_PASSWORD=your-secure-database-password-change-this

# 服务器配置
NODE_ENV=production
PORT=3001

# JWT认证配置
JWT_SECRET=your-jwt-secret-key-change-this-to-random-string
JWT_EXPIRES_IN=24h

# CORS配置
CORS_ORIGIN=https://your-domain.com,https://admin.your-domain.com

# 管理员账户配置（可选）
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@your-domain.com
# 注意：首次部署后请立即修改默认密码

# 日志配置
LOG_LEVEL=info
LOG_FORMAT=json

# 监控配置
METRICS_ENABLED=true
METRICS_PORT=9090

# 安全配置
RATE_LIMIT_WINDOW=15m
RATE_LIMIT_MAX=100

# 备份配置
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"  # 每天凌晨2点
BACKUP_RETENTION_DAYS=30